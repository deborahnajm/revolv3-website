# ── HubSpot Forms integration ────────────────────────────────
# The contact form posts to HubSpot's Forms Submission API v3.
# Copy this file to `.env` (or set these in your host's build env)
# and fill in the Form GUID.

# Your HubSpot Hub ID (Portal ID). Public value. Revolv3 = 22077173.
# Only override if you point the form at a different account.
VITE_HUBSPOT_PORTAL_ID=22077173

# The GUID of the HubSpot form to submit into. REQUIRED to go live.
# Find it in HubSpot: Marketing → Forms → open your form → the GUID is
# in the URL (…/forms/editor/<FORM_GUID>) and in the embed/share code.
VITE_HUBSPOT_FORM_GUID=
